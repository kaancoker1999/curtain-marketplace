// CurtainOS — B2B operating system for the curtain industry.
// Normalized schema supporting multi-vendor orgs (retailers, manufacturers,
// sewing workshops, fabric suppliers, installers, logistics), RFQ + bidding,
// AI matching, production capacity, warehousing, pricing rules and logistics.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Parties
// ---------------------------------------------------------------------------

enum OrgRole {
  RETAILER
  MANUFACTURER
  SEWING_WORKSHOP
  FABRIC_SUPPLIER
  INSTALLER
  LOGISTICS_PROVIDER
  CREATIVE_STUDIO
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  email       String?
  phone       String?
  website     String?
  country     String
  city        String
  verified    Boolean  @default(false)
  // Denormalized rating aggregates so the matching engine can score without joins.
  ratingAvg   Float    @default(0)
  ratingCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles            OrganizationRole[]
  locations        Location[]
  memberships      Membership[]
  products         Product[]
  fabrics          Fabric[]
  services         ServiceOffering[]
  capacities       ProductionCapacity[]
  warehouses       Warehouse[]
  pricingRules     PricingRule[]
  rfqs             Rfq[]                @relation("BuyerRfqs")
  bids             Bid[]
  matchResults     MatchResult[]
  buyerOrders      Order[]              @relation("BuyerOrders")
  sellerOrders     Order[]              @relation("SellerOrders")
  carrierShipments Shipment[]
  reviewsGiven     Review[]             @relation("ReviewsGiven")
  reviewsReceived  Review[]             @relation("ReviewsReceived")
}

// One company can act in several roles (e.g. manufacturer + sewing workshop).
model OrganizationRole {
  id    String  @id @default(cuid())
  orgId String
  role  OrgRole

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, role])
  @@index([role])
}

model Location {
  id          String  @id @default(cuid())
  orgId       String
  label       String
  addressLine String
  city        String
  country     String
  postalCode  String?
  lat         Float?
  lng         Float?
  isPrimary   Boolean @default(false)

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  warehouses Warehouse[]
  shipments  Shipment[]   @relation("ShipmentOrigin")

  @@index([orgId])
}

model User {
  id        String   @id @default(cuid())
  clerkId   String?  @unique // linked once Clerk is enabled
  email     String   @unique
  name      String
  imageUrl  String?
  createdAt DateTime @default(now())

  memberships Membership[]
}

model Membership {
  id     String     @id @default(cuid())
  userId String
  orgId  String
  role   MemberRole @default(MEMBER)

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

// ---------------------------------------------------------------------------
// Catalog: finished products, fabrics, services
// ---------------------------------------------------------------------------

enum ProductCategory {
  CURTAIN
  SHEER
  BLACKOUT
  ROLLER_BLIND
  ZEBRA_BLIND
  VENETIAN_BLIND
  WOOD_BLIND
  ROMAN_SHADE
  CELLULAR_SHADE
  TULLE
  ACCESSORY
}

model Product {
  id           String          @id @default(cuid())
  orgId        String
  name         String
  slug         String          @unique
  description  String?
  category     ProductCategory
  images       String[]
  basePrice    Decimal         @db.Decimal(12, 2)
  currency     String          @default("USD")
  leadTimeDays Int             @default(7)
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  org      Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@index([orgId])
  @@index([category, active])
}

model ProductVariant {
  id         String  @id @default(cuid())
  productId  String
  sku        String  @unique
  widthCm    Int?
  heightCm   Int?
  color      String?
  priceDelta Decimal @default(0) @db.Decimal(12, 2)

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItems InventoryItem[]
  orderItems     OrderItem[]

  @@index([productId])
}

model Fabric {
  id            String   @id @default(cuid())
  orgId         String
  name          String
  sku           String   @unique
  composition   String? // e.g. "70% polyester, 30% cotton"
  color         String?
  pattern       String?
  widthCm       Int // roll width — drives waste optimization
  pricePerMeter Decimal  @db.Decimal(12, 2)
  currency      String   @default("USD")
  stockMeters   Float    @default(0)
  minOrderMeter Float    @default(1)
  imageUrl      String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  org            Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  rfqItems       RfqItem[]
  inventoryItems InventoryItem[]
  orderItems     OrderItem[]

  @@index([orgId, active])
}

enum ServiceType {
  SEWING
  INSTALLATION
  MEASUREMENT
  DESIGN
  PLEATING
  EMBROIDERY
  MOTORIZATION
  LOGISTICS
}

enum PricingModel {
  FIXED
  PER_METER
  PER_SQM
  PER_PANEL
  PER_HOUR
  PER_KM
}

model ServiceOffering {
  id              String       @id @default(cuid())
  orgId           String
  type            ServiceType
  title           String
  description     String?
  pricingModel    PricingModel
  basePrice       Decimal      @db.Decimal(12, 2)
  currency        String       @default("USD")
  minCharge       Decimal?     @db.Decimal(12, 2)
  leadTimeDays    Int          @default(3)
  serviceRadiusKm Int? // installers / measurement teams
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([type, active])
  @@index([orgId])
}

// ---------------------------------------------------------------------------
// Production capacity & warehousing
// ---------------------------------------------------------------------------

model ProductionCapacity {
  id            String   @id @default(cuid())
  orgId         String
  weekStart     DateTime // Monday of the week this row describes
  capacityUnits Int // e.g. panels per week
  bookedUnits   Int      @default(0)
  unit          String   @default("panels")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, weekStart])
}

model Warehouse {
  id         String @id @default(cuid())
  orgId      String
  locationId String
  name       String

  org            Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  location       Location        @relation(fields: [locationId], references: [id])
  inventoryItems InventoryItem[]

  @@index([orgId])
}

model InventoryItem {
  id               String @id @default(cuid())
  warehouseId      String
  productVariantId String?
  fabricId         String?
  quantity         Float
  reserved         Float  @default(0)

  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])
  fabric         Fabric?         @relation(fields: [fabricId], references: [id])

  @@index([warehouseId])
  @@index([productVariantId])
  @@index([fabricId])
}

// ---------------------------------------------------------------------------
// Pricing rules (volume discounts, rush fees, seasonal adjustments…)
// ---------------------------------------------------------------------------

enum PricingRuleType {
  VOLUME_DISCOUNT
  RUSH_FEE
  SEASONAL_ADJUSTMENT
  LOYALTY_DISCOUNT
  MINIMUM_ORDER
}

model PricingRule {
  id        String          @id @default(cuid())
  orgId     String
  type      PricingRuleType
  name      String
  // Rule parameters, e.g. { "minQty": 50, "discountPct": 8 }
  params    Json
  priority  Int             @default(0)
  active    Boolean         @default(true)
  validFrom DateTime?
  validTo   DateTime?

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, active])
}

// ---------------------------------------------------------------------------
// RFQ → matching → bids → orders
// ---------------------------------------------------------------------------

enum RfqStatus {
  DRAFT
  OPEN
  MATCHED
  AWARDED
  CANCELLED
  EXPIRED
}

enum RfqItemType {
  FINISHED_PRODUCT
  FABRIC
  SERVICE
}

model Rfq {
  id              String    @id @default(cuid())
  buyerOrgId      String
  title           String
  description     String?
  status          RfqStatus @default(DRAFT)
  deliveryCity    String
  deliveryCountry String
  deliveryLat     Float?
  deliveryLng     Float?
  neededBy        DateTime?
  budgetMax       Decimal?  @db.Decimal(12, 2)
  currency        String    @default("USD")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  buyer   Organization  @relation("BuyerRfqs", fields: [buyerOrgId], references: [id])
  items   RfqItem[]
  bids    Bid[]
  matches MatchResult[]
  orders  Order[]

  @@index([buyerOrgId, status])
}

model RfqItem {
  id              String           @id @default(cuid())
  rfqId           String
  itemType        RfqItemType
  serviceType     ServiceType?
  productCategory ProductCategory?
  fabricId        String?
  widthCm         Int?
  heightCm        Int?
  quantity        Int              @default(1)
  pleatType       String?
  notes           String?
  specs           Json?

  rfq    Rfq     @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  fabric Fabric? @relation(fields: [fabricId], references: [id])

  @@index([rfqId])
}

enum BidStatus {
  SUBMITTED
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

model Bid {
  id            String    @id @default(cuid())
  rfqId         String
  providerOrgId String
  totalPrice    Decimal   @db.Decimal(12, 2)
  currency      String    @default("USD")
  leadTimeDays  Int
  notes         String?
  status        BidStatus @default(SUBMITTED)
  validUntil    DateTime?
  createdAt     DateTime  @default(now())

  rfq      Rfq          @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  provider Organization @relation(fields: [providerOrgId], references: [id])
  order    Order?

  @@unique([rfqId, providerOrgId])
}

// Output of the AI matching engine, persisted for auditability.
model MatchResult {
  id                    String   @id @default(cuid())
  rfqId                 String
  providerOrgId         String
  rank                  Int
  totalScore            Float
  priceScore            Float
  deliveryScore         Float
  capacityScore         Float
  wasteScore            Float
  logisticsScore        Float
  ratingScore           Float
  estimatedPrice        Decimal? @db.Decimal(12, 2)
  estimatedLeadTimeDays Int?
  explanation           String?
  engineVersion         String
  createdAt             DateTime @default(now())

  rfq      Rfq          @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  provider Organization @relation(fields: [providerOrgId], references: [id])

  @@unique([rfqId, providerOrgId])
  @@index([rfqId, rank])
}

// ---------------------------------------------------------------------------
// Orders, fulfilment, payments, reviews
// ---------------------------------------------------------------------------

enum OrderStatus {
  DRAFT
  CONFIRMED
  IN_PRODUCTION
  QUALITY_CHECK
  READY_FOR_SHIPMENT
  SHIPPED
  DELIVERED
  INSTALLED
  COMPLETED
  CANCELLED
  DISPUTED
}

model Order {
  id           String      @id @default(cuid())
  orderNumber  String      @unique
  buyerOrgId   String
  sellerOrgId  String
  rfqId        String?
  bidId        String?     @unique
  status       OrderStatus @default(DRAFT)
  subtotal     Decimal     @db.Decimal(12, 2)
  shippingCost Decimal     @default(0) @db.Decimal(12, 2)
  total        Decimal     @db.Decimal(12, 2)
  currency     String      @default("USD")
  notes        String?
  placedAt     DateTime    @default(now())
  dueDate      DateTime?
  updatedAt    DateTime    @updatedAt

  buyer        Organization       @relation("BuyerOrders", fields: [buyerOrgId], references: [id])
  seller       Organization       @relation("SellerOrders", fields: [sellerOrgId], references: [id])
  rfq          Rfq?               @relation(fields: [rfqId], references: [id])
  bid          Bid?               @relation(fields: [bidId], references: [id])
  items        OrderItem[]
  statusEvents OrderStatusEvent[]
  shipments    Shipment[]
  payments     Payment[]
  reviews      Review[]

  @@index([buyerOrgId, status])
  @@index([sellerOrgId, status])
}

model OrderItem {
  id                String  @id @default(cuid())
  orderId           String
  productVariantId  String?
  serviceOfferingId String?
  fabricId          String?
  description       String
  quantity          Int
  unitPrice         Decimal @db.Decimal(12, 2)
  totalPrice        Decimal @db.Decimal(12, 2)
  specs             Json?

  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant  ProductVariant?  @relation(fields: [productVariantId], references: [id])
  serviceOffering ServiceOffering? @relation(fields: [serviceOfferingId], references: [id])
  fabric          Fabric?          @relation(fields: [fabricId], references: [id])

  @@index([orderId])
}

model OrderStatusEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

enum ShipmentStatus {
  PENDING
  PICKUP
  IN_TRANSIT
  DELIVERED
  FAILED
}

model Shipment {
  id             String         @id @default(cuid())
  orderId        String
  carrierOrgId   String?
  fromLocationId String?
  toAddress      String
  toCity         String
  toCountry      String
  toLat          Float?
  toLng          Float?
  status         ShipmentStatus @default(PENDING)
  trackingCode   String?
  distanceKm     Float?
  cost           Decimal?       @db.Decimal(12, 2)
  pickedUpAt     DateTime?
  deliveredAt    DateTime?

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier      Organization? @relation(fields: [carrierOrgId], references: [id])
  fromLocation Location?     @relation("ShipmentOrigin", fields: [fromLocationId], references: [id])

  @@index([orderId])
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  REFUNDED
  FAILED
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("USD")
  status      PaymentStatus @default(PENDING)
  provider    String        @default("stripe")
  providerRef String? // Stripe PaymentIntent id once Stripe is enabled
  createdAt   DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Review {
  id                 String   @id @default(cuid())
  orderId            String
  raterOrgId         String
  rateeOrgId         String
  qualityScore       Int // 1–5
  timelinessScore    Int // 1–5
  communicationScore Int // 1–5
  overallScore       Float
  comment            String?
  createdAt          DateTime @default(now())

  order Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rater Organization @relation("ReviewsGiven", fields: [raterOrgId], references: [id])
  ratee Organization @relation("ReviewsReceived", fields: [rateeOrgId], references: [id])

  @@unique([orderId, raterOrgId])
  @@index([rateeOrgId])
}
